# Atlas-Bookmaker · environment template
# Copy to .env and fill in real values · NEVER commit .env

# ─── Hugging Face (Granite-Bee model downloads) ──────────────────────────────
HF_TOKEN=hf_...

# ─── Anthropic (corpus diversity sampler · ~20% of source C) ─────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Hedera (deed anchoring) ─────────────────────────────────────────────────
HEDERA_OPERATOR=0.0.10291827
HEDERA_OPERATOR_KEY=...                                # mainnet ECDSA
HCS_TOPIC=0.0.10291838                                 # deed anchor topic

# ─── Compute targets ─────────────────────────────────────────────────────────
SMASH_HOST=192.168.0.164                              # 5090 · primary cook + serve
SWARMRAILS_HOST=192.168.0.100                         # 2× PRO 6000 · tribunal + Atlas-tier
NAS_HOST=192.168.0.102                                # Synology · NFS root

# ─── Granite stack base paths (smash) ────────────────────────────────────────
GRANITE_BASE=/home/smash/granite
GRANITE_LLM=$GRANITE_BASE/granite-4.1-8b
GRANITE_VISION=$GRANITE_BASE/granite-vision-4.1-4b
GRANITE_DOCLING=$GRANITE_BASE/granite-docling-258M
GRANITE_SPEECH=$GRANITE_BASE/granite-speech-4.1-2b-nar
GRANITE_GUARDIAN=$GRANITE_BASE/granite-guardian-4.1-8b

# ─── Corpus paths (NAS) ──────────────────────────────────────────────────────
CORPUS_ROOT=/tmp/swarm-nfs/atlas-bookmaker/v2
CRE_HONEY=/tmp/swarm-nfs/swarm-and-bee-datasets/cre/cre_honey_stamped.jsonl
SWARMMARKET_HONEY=/tmp/swarm-nfs/swarm-and-bee-datasets/marketing/swarmmarket_honey.jsonl

# ─── Tribunal endpoints (swarmrails Ollama) ──────────────────────────────────
TRIBUNAL_JUDGE_A=http://swarmrails:11434/api/generate  # gemma3:12b on GPU0
TRIBUNAL_JUDGE_B=http://swarmrails:11435/api/generate  # qwen2.5:32b on GPU1

# ─── Honey ledger (provenance) ───────────────────────────────────────────────
HONEY_LEDGER_DB=/data2/swarmdev/honey_ledger.db        # on swarmrails
HONEY_LEDGER_REMOTE=swarm@swarmrails:$HONEY_LEDGER_DB

# ─── Discord (cook auditor + ship notifications) ─────────────────────────────
DISCORD_WEBHOOK_URL=                                   # #cook-auditor channel

# ─── BeeAI code-interpreter sandbox ──────────────────────────────────────────
CODE_INTERPRETER_URL=http://127.0.0.1:50081           # IBM-published Docker image
CODE_INTERPRETER_TMPDIR=./tmp/ci

# ─── vLLM serve (production endpoint) ────────────────────────────────────────
VLLM_PORT=8089                                         # smash:8089 · production
VLLM_ADAPTER_PATH=/home/smash/atlas-bookmaker_v2/merged/atlas-bookmaker-v2

# ─── API gateway ─────────────────────────────────────────────────────────────
API_BASE_URL=https://api.swarmandbee.ai
BOOKMAKER_ROUTE=/v1/atlas/bookmaker
